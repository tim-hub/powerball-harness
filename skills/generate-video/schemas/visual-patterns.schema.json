{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/visual-patterns.schema.json",
  "title": "Visual Patterns Schema",
  "description": "Schema for image generation patterns. Defines 4 pattern types: comparison, concept, flow, and highlight.",
  "version": "1.0.0",
  "type": "object",
  "required": ["type", "topic"],
  "properties": {
    "type": {
      "type": "string",
      "description": "Image pattern type",
      "enum": ["comparison", "concept", "flow", "highlight"]
    },
    "topic": {
      "type": "string",
      "description": "Image subject/theme",
      "minLength": 1,
      "maxLength": 200
    },
    "style": {
      "type": "string",
      "description": "Visual style (optional)",
      "enum": ["minimalist", "technical", "modern", "gradient", "flat", "3d"],
      "default": "modern"
    },
    "color_scheme": {
      "type": "object",
      "description": "Color scheme settings",
      "properties": {
        "primary": {
          "type": "string",
          "description": "Primary color (e.g., #3B82F6)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary": {
          "type": "string",
          "description": "Secondary color (e.g., #10B981)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "accent": {
          "type": "string",
          "description": "Accent color (e.g., #F59E0B)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "background": {
          "type": "string",
          "description": "Background color (e.g., #1F2937)",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#1F2937"
        }
      },
      "additionalProperties": false
    },
    "comparison": {
      "type": "object",
      "description": "Settings for the comparison pattern",
      "required": ["left_side", "right_side"],
      "properties": {
        "left_side": {
          "type": "object",
          "description": "Left side (Before / Bad example)",
          "required": ["label", "items"],
          "properties": {
            "label": {
              "type": "string",
              "description": "Label (e.g., Before, Bad example)",
              "minLength": 1,
              "maxLength": 50
            },
            "items": {
              "type": "array",
              "description": "List of display items",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "minItems": 1,
              "maxItems": 5
            },
            "icon": {
              "type": "string",
              "description": "Icon type (e.g., x, warning, sad)",
              "enum": ["x", "warning", "sad", "slow", "confused", "broken"]
            },
            "sentiment": {
              "type": "string",
              "description": "Sentiment/impression",
              "enum": ["negative", "neutral", "caution"],
              "default": "negative"
            }
          },
          "additionalProperties": false
        },
        "right_side": {
          "type": "object",
          "description": "Right side (After / Good example)",
          "required": ["label", "items"],
          "properties": {
            "label": {
              "type": "string",
              "description": "Label (e.g., After, Good example)",
              "minLength": 1,
              "maxLength": 50
            },
            "items": {
              "type": "array",
              "description": "List of display items",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "minItems": 1,
              "maxItems": 5
            },
            "icon": {
              "type": "string",
              "description": "Icon type (e.g., check, star, happy)",
              "enum": ["check", "star", "happy", "fast", "clear", "solid"]
            },
            "sentiment": {
              "type": "string",
              "description": "Sentiment/impression",
              "enum": ["positive", "neutral", "success"],
              "default": "positive"
            }
          },
          "additionalProperties": false
        },
        "divider": {
          "type": "string",
          "description": "Divider type",
          "enum": ["arrow", "vs", "line", "gradient"],
          "default": "arrow"
        }
      },
      "additionalProperties": false
    },
    "concept": {
      "type": "object",
      "description": "Settings for the concept diagram pattern",
      "required": ["elements"],
      "properties": {
        "elements": {
          "type": "array",
          "description": "List of concept elements",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique ID of the element",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "Element label",
                "minLength": 1,
                "maxLength": 50
              },
              "description": {
                "type": "string",
                "description": "Element description (optional)",
                "maxLength": 200
              },
              "level": {
                "type": "integer",
                "description": "Hierarchy level (0 = top level)",
                "minimum": 0,
                "maximum": 5,
                "default": 0
              },
              "parent_id": {
                "type": "string",
                "description": "Parent element ID (for expressing hierarchy)",
                "pattern": "^[a-z0-9_-]+$"
              },
              "icon": {
                "type": "string",
                "description": "Icon type",
                "enum": ["box", "circle", "diamond", "hexagon", "cloud", "gear", "database", "server", "user", "code"]
              },
              "emphasis": {
                "type": "string",
                "description": "Emphasis level",
                "enum": ["high", "medium", "low"],
                "default": "medium"
              }
            },
            "additionalProperties": false
          },
          "minItems": 2,
          "maxItems": 10
        },
        "relationships": {
          "type": "array",
          "description": "Relationships between elements",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "description": "Source element ID of the relationship",
                "pattern": "^[a-z0-9_-]+$"
              },
              "to": {
                "type": "string",
                "description": "Target element ID of the relationship",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "Relationship label (e.g., contains, generates, depends on)",
                "maxLength": 30
              },
              "type": {
                "type": "string",
                "description": "Relationship type",
                "enum": ["hierarchy", "flow", "dependency", "association"],
                "default": "association"
              },
              "bidirectional": {
                "type": "boolean",
                "description": "Whether the relationship is bidirectional",
                "default": false
              }
            },
            "additionalProperties": false
          }
        },
        "layout": {
          "type": "string",
          "description": "Layout type",
          "enum": ["hierarchy", "radial", "grid", "flow", "circular"],
          "default": "hierarchy"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "description": "Settings for the flow diagram pattern",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "description": "Flow steps",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique ID of the step",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "Step label",
                "minLength": 1,
                "maxLength": 50
              },
              "description": {
                "type": "string",
                "description": "Detailed description of the step",
                "maxLength": 150
              },
              "order": {
                "type": "integer",
                "description": "Step order (1-based)",
                "minimum": 1,
                "maximum": 20
              },
              "type": {
                "type": "string",
                "description": "Step type",
                "enum": ["start", "process", "decision", "end", "parallel", "subprocess"],
                "default": "process"
              },
              "icon": {
                "type": "string",
                "description": "Icon type",
                "enum": ["circle", "square", "diamond", "rounded", "hexagon"]
              },
              "duration": {
                "type": "string",
                "description": "Estimated duration (e.g., 2 min, instant)",
                "maxLength": 20
              }
            },
            "additionalProperties": false
          },
          "minItems": 2,
          "maxItems": 10
        },
        "direction": {
          "type": "string",
          "description": "Flow direction",
          "enum": ["horizontal", "vertical", "zigzag"],
          "default": "horizontal"
        },
        "arrow_style": {
          "type": "string",
          "description": "Arrow style",
          "enum": ["solid", "dashed", "dotted", "thick", "animated"],
          "default": "solid"
        },
        "show_numbers": {
          "type": "boolean",
          "description": "Whether to show step numbers",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "highlight": {
      "type": "object",
      "description": "Settings for the highlight pattern",
      "required": ["main_text"],
      "properties": {
        "main_text": {
          "type": "string",
          "description": "Main text (content to emphasize)",
          "minLength": 1,
          "maxLength": 100
        },
        "sub_text": {
          "type": "string",
          "description": "Sub text (supplementary description)",
          "maxLength": 150
        },
        "icon": {
          "type": "string",
          "description": "Icon type",
          "enum": ["star", "check", "alert", "info", "trophy", "rocket", "fire", "bolt", "heart", "none"],
          "default": "none"
        },
        "position": {
          "type": "string",
          "description": "Text position",
          "enum": ["center", "top", "bottom", "left", "right"],
          "default": "center"
        },
        "effect": {
          "type": "string",
          "description": "Visual effect",
          "enum": ["glow", "shadow", "gradient", "outline", "none"],
          "default": "glow"
        },
        "font_size": {
          "type": "string",
          "description": "Font size",
          "enum": ["small", "medium", "large", "xlarge"],
          "default": "large"
        },
        "emphasis": {
          "type": "string",
          "description": "Emphasis level",
          "enum": ["high", "medium", "low"],
          "default": "high"
        }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "object",
      "description": "Image size settings",
      "properties": {
        "width": {
          "type": "integer",
          "description": "Width (pixels)",
          "minimum": 256,
          "maximum": 2048,
          "default": 1920
        },
        "height": {
          "type": "integer",
          "description": "Height (pixels)",
          "minimum": 256,
          "maximum": 2048,
          "default": 1080
        },
        "aspect_ratio": {
          "type": "string",
          "description": "Aspect ratio",
          "enum": ["16:9", "4:3", "1:1", "9:16"],
          "default": "16:9"
        }
      },
      "additionalProperties": false
    },
    "generation": {
      "type": "object",
      "description": "Generation settings",
      "properties": {
        "seed": {
          "type": "integer",
          "description": "Deterministic seed value (for reproducibility)",
          "minimum": 0
        },
        "quality": {
          "type": "string",
          "description": "Image quality",
          "enum": ["draft", "standard", "high"],
          "default": "standard"
        },
        "retries": {
          "type": "integer",
          "description": "Maximum retry count on quality failure",
          "minimum": 0,
          "maximum": 5,
          "default": 3
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "description": "Metadata (additional information)",
      "properties": {
        "scene_id": {
          "type": "string",
          "description": "Associated scene ID"
        },
        "purpose": {
          "type": "string",
          "description": "Image purpose (e.g., intro, demo, cta)",
          "maxLength": 50
        },
        "tags": {
          "type": "array",
          "description": "Tags",
          "items": {
            "type": "string",
            "maxLength": 30
          },
          "maxItems": 10
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "type": { "const": "comparison" }
      },
      "required": ["comparison"]
    },
    {
      "properties": {
        "type": { "const": "concept" }
      },
      "required": ["concept"]
    },
    {
      "properties": {
        "type": { "const": "flow" }
      },
      "required": ["flow"]
    },
    {
      "properties": {
        "type": { "const": "highlight" }
      },
      "required": ["highlight"]
    }
  ]
}
