{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/animation.schema.json",
  "title": "Animation Schema",
  "description": "Schema for animation settings. Defines transitions, easing, and spring physics parameters.",
  "version": "1.0.0",
  "type": "object",
  "required": ["type", "duration_ms"],
  "properties": {
    "type": {
      "type": "string",
      "description": "Animation type",
      "enum": ["fade", "slide_in", "zoom", "cut", "spring", "rotate", "scale"]
    },
    "duration_ms": {
      "type": "integer",
      "description": "Animation duration (milliseconds)",
      "minimum": 0,
      "maximum": 10000
    },
    "easing": {
      "type": "string",
      "description": "Easing function (ignored for spring type)",
      "enum": ["linear", "easeIn", "easeOut", "easeInOut", "easeInQuad", "easeOutQuad", "easeInOutQuad", "easeInCubic", "easeOutCubic", "easeInOutCubic"],
      "default": "easeInOut"
    },
    "spring": {
      "type": "object",
      "description": "Spring physics parameters (only applied when type is spring)",
      "properties": {
        "damping": {
          "type": "number",
          "description": "Damping (decay coefficient). Higher values stop faster",
          "minimum": 1,
          "maximum": 500,
          "default": 200
        },
        "stiffness": {
          "type": "number",
          "description": "Stiffness (spring rigidity). Higher values produce stronger bounce",
          "minimum": 1,
          "maximum": 500,
          "default": 100
        },
        "mass": {
          "type": "number",
          "description": "Mass. Higher values produce heavier motion",
          "minimum": 0.1,
          "maximum": 10,
          "default": 1
        },
        "overshoot_clamping": {
          "type": "boolean",
          "description": "Whether to suppress overshoot (overshooting)",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "delay_ms": {
      "type": "integer",
      "description": "Delay before animation start (milliseconds)",
      "minimum": 0,
      "default": 0
    },
    "from": {
      "type": "object",
      "description": "Values at animation start",
      "properties": {
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "x": {
          "type": "number",
          "description": "X-coordinate offset (pixels)"
        },
        "y": {
          "type": "number",
          "description": "Y-coordinate offset (pixels)"
        },
        "scale": {
          "type": "number",
          "description": "Scale value",
          "minimum": 0
        },
        "rotate": {
          "type": "number",
          "description": "Rotation angle (degrees)"
        }
      },
      "additionalProperties": false
    },
    "to": {
      "type": "object",
      "description": "Values at animation end",
      "properties": {
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "x": {
          "type": "number",
          "description": "X-coordinate offset (pixels)"
        },
        "y": {
          "type": "number",
          "description": "Y-coordinate offset (pixels)"
        },
        "scale": {
          "type": "number",
          "description": "Scale value",
          "minimum": 0
        },
        "rotate": {
          "type": "number",
          "description": "Rotation angle (degrees)"
        }
      },
      "additionalProperties": false
    },
    "interpolate": {
      "type": "object",
      "description": "Detailed settings for the Remotion interpolate function",
      "properties": {
        "input_range": {
          "type": "array",
          "description": "Input range (array of frame numbers)",
          "items": {
            "type": "number"
          },
          "minItems": 2
        },
        "output_range": {
          "type": "array",
          "description": "Output range (array of values)",
          "items": {
            "type": "number"
          },
          "minItems": 2
        },
        "extrapolate_left": {
          "type": "string",
          "description": "Left extrapolation method (out of range)",
          "enum": ["clamp", "extend", "identity"],
          "default": "clamp"
        },
        "extrapolate_right": {
          "type": "string",
          "description": "Right extrapolation method (out of range)",
          "enum": ["clamp", "extend", "identity"],
          "default": "clamp"
        }
      },
      "additionalProperties": false
    },
    "loop": {
      "type": "object",
      "description": "Loop settings (optional)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable looping",
          "default": false
        },
        "count": {
          "type": "integer",
          "description": "Loop count (0 for infinite loop)",
          "minimum": 0,
          "default": 0
        },
        "reverse": {
          "type": "boolean",
          "description": "Whether to use ping-pong loop (forward then reverse)",
          "default": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
