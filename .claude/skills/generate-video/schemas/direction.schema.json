{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/direction.schema.json",
  "title": "Direction Schema",
  "description": "Schema for the direction system. Defines per-scene direction parameters (transitions, emphasis, backgrounds, timing).",
  "version": "1.0.0",
  "type": "object",
  "required": ["scene_id", "transition", "emphasis", "background", "timing"],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "Target scene ID (must match a scene in the scenario)",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "transition": {
      "type": "object",
      "description": "Transition settings for this scene",
      "required": ["type", "duration_ms"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Transition type",
          "enum": ["fade", "slide_in", "zoom", "cut"]
        },
        "duration_ms": {
          "type": "integer",
          "description": "Transition duration (milliseconds)",
          "minimum": 0,
          "maximum": 2000,
          "default": 500
        },
        "easing": {
          "type": "string",
          "description": "Easing function",
          "enum": ["linear", "easeIn", "easeOut", "easeInOut"],
          "default": "easeInOut"
        },
        "direction": {
          "type": "string",
          "description": "Slide direction (only for slide_in)",
          "enum": ["left", "right", "top", "bottom"],
          "default": "right"
        }
      },
      "additionalProperties": false
    },
    "emphasis": {
      "type": "object",
      "description": "Emphasis expression within the scene",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "description": "Emphasis level",
          "enum": ["high", "medium", "low"]
        },
        "text": {
          "type": "array",
          "description": "Text elements to emphasize (keywords/phrases)",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "sound": {
          "type": "string",
          "description": "Sound effect type",
          "enum": ["none", "pop", "whoosh", "chime", "ding"],
          "default": "none"
        },
        "color": {
          "type": "string",
          "description": "Emphasis color (HEX format)",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#00F5FF"
        },
        "position": {
          "type": "string",
          "description": "Emphasis element position",
          "enum": ["center", "top", "bottom", "left", "right"],
          "default": "center"
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "description": "Background settings",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Background type",
          "enum": ["cyberpunk", "corporate", "minimal", "gradient", "particles"]
        },
        "primary_color": {
          "type": "string",
          "description": "Primary color (HEX format)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary_color": {
          "type": "string",
          "description": "Secondary color (HEX format)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "opacity": {
          "type": "number",
          "description": "Background opacity",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "blur": {
          "type": "boolean",
          "description": "Whether to apply blur to the background",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "timing": {
      "type": "object",
      "description": "Timing adjustments within the scene",
      "properties": {
        "delay_before_ms": {
          "type": "integer",
          "description": "Wait time before scene start (milliseconds)",
          "minimum": 0,
          "default": 0
        },
        "delay_after_ms": {
          "type": "integer",
          "description": "Wait time after scene end (milliseconds)",
          "minimum": 0,
          "default": 0
        },
        "audio_start_offset_ms": {
          "type": "integer",
          "description": "Audio start offset (milliseconds, positive = delay, negative = advance)",
          "default": 1000
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
