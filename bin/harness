#!/bin/sh
OS="$(uname -s | tr A-Z a-z)"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  ARCH="amd64" ;;
  aarch64) ARCH="arm64" ;;
esac
BINARY="$(dirname "$0")/harness-${OS}-${ARCH}"
if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
else
  # Binary not yet installed — fail open so hooks don't block the user.
  # Warn once per install so the user knows guardrails are inactive.
  FLAG="${HOME}/.claude/harness-binary-missing.warned"
  if [ ! -f "$FLAG" ]; then
    mkdir -p "$(dirname "$FLAG")"
    echo "[harness] binary not installed — guardrails inactive. Run /harness-setup binary to install." >&2
    touch "$FLAG"
  fi
  exit 0
fi
