#!/bin/sh
OS="$(uname -s | tr A-Z a-z)"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  ARCH="amd64" ;;
  aarch64) ARCH="arm64" ;;
esac
BINARY="$(dirname "$0")/harness-${OS}-${ARCH}"
if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
else
  # Binary not yet installed — fail open so hooks don't block the user.
  # Run /harness-setup to install the binary for your platform.
  exit 0
fi
