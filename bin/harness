#!/bin/sh
# Harness runtime shim — dispatches to platform-specific Go binary.
# On missing binary: emit diagnostic on stderr, exit 0 with EMPTY stdout
# so CC hooks treat it as "no decision" (proceed normally) and non-hook
# subcommands (doctor, sync, validate) no-op silently.
# Never print JSON here — we don't know which hook/command is being
# called and emitting the wrong schema breaks the hook protocol.

SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="${SCRIPT_DIR}/${LINK_TARGET}" ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

OS="$(uname -s | tr A-Z a-z)"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  ARCH="amd64" ;;
  aarch64) ARCH="arm64" ;;
esac
BINARY="${SCRIPT_DIR}/harness-${OS}-${ARCH}"
if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
fi

printf 'claude-code-harness: no binary for %s-%s at %s (command %s skipped).\n' \
  "$OS" "$ARCH" "$BINARY" "${1:-<none>}" >&2
exit 0
