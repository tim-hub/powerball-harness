#!/bin/sh
OS="$(uname -s | tr A-Z a-z)"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  ARCH="amd64" ;;
  aarch64) ARCH="arm64" ;;
esac
SELF="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
BINARY="$(dirname "$SELF")/harness-${OS}-${ARCH}"
if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
else
  # Binary not found — fail open so hooks don't block the user.
  # Prebuilt binaries ship in harness/bin/; if missing, run 'make build-all' to rebuild from source.
  FLAG="${HOME}/.claude/harness-binary-missing.warned"
  if [ ! -f "$FLAG" ]; then
    mkdir -p "$(dirname "$FLAG")"
    echo "[harness] binary not found — guardrails inactive. Run 'make build-all' to rebuild from source." >&2
    touch "$FLAG"
  fi
  exit 0
fi
