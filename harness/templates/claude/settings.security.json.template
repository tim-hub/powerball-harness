{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_harness_template": "claude/settings.security.json.template",
  "_harness_version": "2.21.1",
  "_harness_note": "Project-level settings template. Plugin defaults (.claude-plugin/settings.json) provide baseline deny/ask only; allow rules belong here at project scope.",
  "language": "english",
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(bun test:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run build:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(mongo:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.npmrc)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(bun install:*)",
      "Bash(pnpm install:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run start:*)",
      "Bash(bun run dev:*)",
      "Bash(bun run start:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)"
    ]
  }
}
