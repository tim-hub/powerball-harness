{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Sandbox settings template - enhance security while minimizing impact on usability",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "watchman",
      "systemctl",
      "launchctl",
      "brew services"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com",
        "pypi.org",
        "rubygems.org",
        "crates.io"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  },
  "_notes": {
    "purpose": "Recommended Sandbox settings based on Claude Code Permissions documentation",
    "autoAllowBashIfSandboxed": "Setting to true minimizes permission prompts when Sandbox is enabled",
    "excludedCommands": "Commands that need to run outside the Sandbox (require host system access)",
    "allowedDomains": "Allow network access to external services needed for development"
  }
}
