# Harness release preflight configuration
# Copy to .env and adjust values for your environment.

# Custom healthcheck command run during release preflight.
# Must exit 0 to pass. Runs via bash -lc so PATH and shell aliases are available.
HARNESS_RELEASE_HEALTHCHECK_CMD=make validate && make test-all

# Custom CI status command (optional). Overrides the default gh-based CI check.
# HARNESS_RELEASE_CI_STATUS_CMD=gh run list --limit 1 --json conclusion --jq '.[0].conclusion'

# Override the plugin root used by the preflight script (optional).
# Defaults to the repository root inferred from the script location.
# HARNESS_RELEASE_PLUGIN_ROOT=/path/to/repo
