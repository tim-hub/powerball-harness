{
  "name": "@claude-code-harness/core",
  "version": "3.0.0",
  "description": "Claude Code Harness v3 — TypeScript core engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
