{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/emphasis.schema.json",
  "title": "Emphasis Schema",
  "description": "Schema for emphasis expressions. Defines text emphasis, sound effects, colors, and positioning.",
  "version": "1.0.0",
  "type": "object",
  "required": ["level"],
  "properties": {
    "level": {
      "type": "string",
      "description": "Emphasis level",
      "enum": ["high", "medium", "low"]
    },
    "text": {
      "type": "array",
      "description": "Text elements to emphasize (keywords/phrases)",
      "items": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "Text content to emphasize"
          },
          "start_ms": {
            "type": "integer",
            "description": "Emphasis start time (relative position within the scene, in milliseconds)",
            "minimum": 0
          },
          "duration_ms": {
            "type": "integer",
            "description": "Emphasis display duration (milliseconds)",
            "minimum": 1,
            "default": 1000
          },
          "style": {
            "type": "string",
            "description": "Text style",
            "enum": ["bold", "glitch", "underline", "highlight", "glow"],
            "default": "bold"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "sound": {
      "type": "object",
      "description": "Sound effect settings",
      "properties": {
        "type": {
          "type": "string",
          "description": "Sound effect type",
          "enum": ["none", "pop", "whoosh", "chime", "ding"],
          "default": "none"
        },
        "volume": {
          "type": "number",
          "description": "Volume (0.0-1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "timing": {
          "type": "string",
          "description": "Sound effect timing",
          "enum": ["start", "end", "peak"],
          "default": "start"
        },
        "trigger_ms": {
          "type": "integer",
          "description": "Sound effect trigger time (relative position within the scene, in milliseconds)",
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "color": {
      "type": "object",
      "description": "Emphasis color settings",
      "properties": {
        "primary": {
          "type": "string",
          "description": "Primary color (HEX format)",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#00F5FF"
        },
        "secondary": {
          "type": "string",
          "description": "Secondary color (HEX format, for gradients)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "glow": {
          "type": "boolean",
          "description": "Whether to apply glow effect",
          "default": true
        },
        "glow_intensity": {
          "type": "number",
          "description": "Glow intensity (blur radius, pixels)",
          "minimum": 0,
          "maximum": 100,
          "default": 20
        }
      },
      "additionalProperties": false
    },
    "position": {
      "type": "object",
      "description": "Emphasis element position settings",
      "properties": {
        "alignment": {
          "type": "string",
          "description": "Alignment position",
          "enum": ["center", "top", "bottom", "left", "right", "top_left", "top_right", "bottom_left", "bottom_right"],
          "default": "center"
        },
        "offset": {
          "type": "object",
          "description": "Position offset (pixels)",
          "properties": {
            "x": {
              "type": "number",
              "description": "X-axis offset",
              "default": 0
            },
            "y": {
              "type": "number",
              "description": "Y-axis offset",
              "default": 0
            }
          },
          "additionalProperties": false
        },
        "padding": {
          "type": "number",
          "description": "Padding from screen edges (pixels)",
          "minimum": 0,
          "default": 40
        }
      },
      "additionalProperties": false
    },
    "animation": {
      "type": "object",
      "description": "Emphasis display animation settings",
      "properties": {
        "entry": {
          "type": "string",
          "description": "Entry animation",
          "enum": ["none", "fade_in", "slide_in", "zoom_in", "bounce"],
          "default": "fade_in"
        },
        "exit": {
          "type": "string",
          "description": "Exit animation",
          "enum": ["none", "fade_out", "slide_out", "zoom_out"],
          "default": "fade_out"
        },
        "duration_ms": {
          "type": "integer",
          "description": "Animation duration (milliseconds)",
          "minimum": 1,
          "maximum": 2000,
          "default": 500
        },
        "pulse": {
          "type": "boolean",
          "description": "Whether to enable pulse effect (blink/scale)",
          "default": false
        },
        "pulse_speed": {
          "type": "number",
          "description": "Pulse speed (cycles per second)",
          "minimum": 0.1,
          "maximum": 10,
          "default": 1.0
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "description": "Emphasis element background settings (box display, etc.)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to show background",
          "default": false
        },
        "color": {
          "type": "string",
          "description": "Background color (HEX format or RGBA)",
          "default": "rgba(0, 0, 0, 0.8)"
        },
        "border_radius": {
          "type": "number",
          "description": "Border radius (pixels)",
          "minimum": 0,
          "default": 8
        },
        "padding": {
          "type": "object",
          "description": "Padding within background (pixels)",
          "properties": {
            "top": {
              "type": "number",
              "minimum": 0,
              "default": 16
            },
            "right": {
              "type": "number",
              "minimum": 0,
              "default": 32
            },
            "bottom": {
              "type": "number",
              "minimum": 0,
              "default": 16
            },
            "left": {
              "type": "number",
              "minimum": 0,
              "default": 32
            }
          },
          "additionalProperties": false
        },
        "border": {
          "type": "object",
          "description": "Border settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "width": {
              "type": "number",
              "minimum": 0,
              "default": 2
            },
            "color": {
              "type": "string",
              "description": "Border color (HEX format)",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "default": "#00F5FF"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "description": "Typography settings",
      "properties": {
        "font_size": {
          "type": "number",
          "description": "Font size (pixels)",
          "minimum": 12,
          "maximum": 200,
          "default": 48
        },
        "font_weight": {
          "type": ["string", "number"],
          "description": "Font weight",
          "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900, "normal", "bold"],
          "default": 700
        },
        "font_family": {
          "type": "string",
          "description": "Font family",
          "default": "sans-serif"
        },
        "line_height": {
          "type": "number",
          "description": "Line height (multiplier)",
          "minimum": 0.5,
          "maximum": 3,
          "default": 1.5
        },
        "letter_spacing": {
          "type": "number",
          "description": "Letter spacing (pixels)",
          "default": 0
        },
        "text_transform": {
          "type": "string",
          "description": "Text transform",
          "enum": ["none", "uppercase", "lowercase", "capitalize"],
          "default": "none"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
