#!/usr/bin/env bash
#
# pre-commit hook (repo-managed)
#
# Purpose:
# - Keep VERSION and .claude-plugin/marketplace.json in sync when release metadata is edited.
# - Never auto-bump versions for ordinary code/docs commits.
#
# Install:
#   ./scripts/install-git-hooks.sh
#

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
  exit 0
fi

cd "$ROOT"

METADATA_FILES=(VERSION .claude-plugin/marketplace.json)
CHANGED_METADATA="$(git diff --cached --name-only -- "${METADATA_FILES[@]}" 2>/dev/null | grep -v '^$' || true)"

if [ -z "$CHANGED_METADATA" ]; then
  exit 0
fi

if [ ! -f "./scripts/sync-version.sh" ]; then
  exit 0
fi

if bash ./scripts/sync-version.sh check >/dev/null 2>&1; then
  exit 0
fi

echo "[pre-commit] Release metadata mismatch detected."
echo "             VERSION is the source of truth; syncing marketplace.json to match."

bash ./scripts/sync-version.sh sync

git add VERSION .claude-plugin/marketplace.json 2>/dev/null || true

SYNCED_VERSION="$(tr -d '[:space:]' < VERSION)"
echo "[pre-commit] Version metadata synced to $SYNCED_VERSION"

exit 0
