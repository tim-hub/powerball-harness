{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(mongo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "mcp__codex__*",
      "Edit(.claude-plugin/settings*)",
      "Edit(.claude/settings*)",
      "Write(.claude-plugin/settings*)",
      "Write(.claude/settings*)",
      "MultiEdit(.claude-plugin/settings*)",
      "MultiEdit(.claude/settings*)",
      "Edit(.eslintrc*)",
      "Edit(eslint.config.*)",
      "Edit(biome.json)",
      "Edit(tsconfig*.json)",
      "Edit(.github/workflows/*)",
      "Write(.eslintrc*)",
      "Write(eslint.config.*)",
      "Write(biome.json)",
      "Write(tsconfig*.json)",
      "Write(.github/workflows/*)",
      "MultiEdit(.eslintrc*)",
      "MultiEdit(eslint.config.*)",
      "MultiEdit(biome.json)",
      "MultiEdit(tsconfig*.json)",
      "MultiEdit(.github/workflows/*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.npmrc)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(bun install:*)",
      "Bash(pnpm install:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": true,
    "filesystem": {
      "denyWrite": [
        ".claude-plugin/settings*",
        ".claude/settings*"
      ],
      "denyRead": [
        ".env",
        ".env.*",
        "!.env.example",
        "secrets/**",
        "**/*.pem",
        "**/*.key",
        "**/*id_rsa*",
        "**/*id_ed25519*",
        "**/.aws/**",
        "**/.ssh/**"
      ],
      "allowRead": [
        ".env.example",
        ".env.sample",
        "config/public-*",
        "docs/**"
      ]
    }
  }
}
