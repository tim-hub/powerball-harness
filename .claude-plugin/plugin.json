{
  "name": "claude-code-harness",
  "version": "4.1.1",
  "description": "Claude harness - A harness for solo developers (Vibecoders) to handle full-cycle contract development.",
  "author": {
    "name": "Chachamaru",
    "url": "https://github.com/Chachamaru127"
  },
  "homepage": "https://github.com/Chachamaru127/claude-code-harness",
  "repository": "https://github.com/Chachamaru127/claude-code-harness",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "vibecoder",
    "workflow",
    "plan-work-review"
  ],
  "skills": [
    "./skills/"
  ],
  "monitors": [
    {
      "id": "harness-session-monitor",
      "name": "Harness Session Monitor",
      "description": "Auto-arm session monitoring for harness-mem health, advisor/reviewer state, and Plans.md drift.",
      "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/harness\" hook session-monitor",
      "autoArm": [
        "plugin_enable",
        "skill_invoke"
      ]
    }
  ],
  "outputStyles": "./output-styles/"
}
