+def generate_report(data: List[Dict], fmt: str = "text") -> str:
+    """Generate a formatted report from a list of data rows.
+
+    Args:
+        data: List of row dictionaries to include in the report.
+        fmt: Output format; "text" for key=value pairs, anything else for repr.
+
+    Returns:
+        The formatted report as a single string.
+    """
+    timestamp = datetime.utcnow().isoformat()
+    header = f"Report generated at {timestamp}"
+    separator = "-" * 40
+    body_lines = [_format_row(row, fmt) for row in data]
+    footer = f"Total rows: {len(data)}"
+    sections = [header, separator, *body_lines, separator, footer]
+    return "\n".join(sections)
+
+
+def _format_row(row: Dict, fmt: str) -> str:
+    """Return a single row formatted according to fmt."""
+    if fmt == "text":
+        return ", ".join(f"{k}={v}" for k, v in row.items())
+    return repr(row)
