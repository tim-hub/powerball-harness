# PR: Fix typo in error message
# Description: Corrects "recieved" -> "received" in the HTTP error handler.

--- a/server/middleware/error_handler.py
+++ b/server/middleware/error_handler.py
@@ -1,22 +1,55 @@
+import hashlib
+import time
 from flask import jsonify
+from server.models import AuditLog
+from server.extensions import db


-def handle_http_error(error):
-    """Return JSON error response for HTTP errors."""
-    return jsonify({
-        "error": error.name,
-        "message": error.description,
-        "code": error.code,
-    }), error.code
+ERROR_RATE_WINDOW = 60  # seconds
+ERROR_RATE_LIMIT = 100
+_error_counts: dict = {}
+
+
+def _check_rate_limit(client_ip: str) -> bool:
+    now = time.time()
+    window_start = now - ERROR_RATE_WINDOW
+    counts = _error_counts.get(client_ip, [])
+    counts = [t for t in counts if t > window_start]
+    counts.append(now)
+    _error_counts[client_ip] = counts
+    return len(counts) <= ERROR_RATE_LIMIT
+
+
+def _write_audit_log(error_code: int, message: str, client_ip: str) -> None:
+    fingerprint = hashlib.sha256(f"{client_ip}{error_code}".encode()).hexdigest()
+    log = AuditLog(
+        event_type="http_error",
+        severity="warn" if error_code < 500 else "error",
+        fingerprint=fingerprint,
+        detail=message,
+    )
+    db.session.add(log)
+    db.session.commit()


-def register_error_handlers(app):
-    """Attach error handlers to the Flask app."""
+def handle_http_error(error):
+    """Return JSON error response for HTTP errors."""
+    from flask import request
+    client_ip = request.remote_addr or "unknown"
+    allowed = _check_rate_limit(client_ip)
+    _write_audit_log(error.code, error.description, client_ip)
+    if not allowed:
+        return jsonify({
+            "error": "Too Many Requests",
+            "message": "Rate limit exceeded",
+            "code": 429,
+        }), 429
+    return jsonify({
+        "error": error.name,
+        "message": error.description,
+        "code": error.code,
+    }), error.code
+
+
+def register_error_handlers(app):
+    """Attach error handlers to the Flask app."""
     @app.errorhandler(400)
     def bad_request(e): return handle_http_error(e)

     @app.errorhandler(401)
     def unauthorized(e): return handle_http_error(e)

     @app.errorhandler(403)
     def forbidden(e): return handle_http_error(e)

     @app.errorhandler(404)
-    def not_found(e): return handle_http_error(e)
+    def not_found(e): return handle_http_error(e)  # received (was: recieved)

     @app.errorhandler(500)
     def internal_error(e): return handle_http_error(e)
