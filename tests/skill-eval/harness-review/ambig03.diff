# PR: Refactor auth middleware to use class-based approach
# Description: Convert function-based middleware to class for better extensibility

--- a/auth/middleware.py
+++ b/auth/middleware.py
@@ -1,28 +1,30 @@
-def require_auth(f):
-    def wrapper(request, *args, **kwargs):
-        token = request.headers.get("Authorization", "").removeprefix("Bearer ")
-        if not token:
-            return Response(status=401)
-        user = verify_token(token)
-        if not user:
-            return Response(status=403)
-        request.user = user
-        return f(request, *args, **kwargs)
-    return wrapper
+class AuthMiddleware:
+    def __init__(self, app):
+        self.app = app
+
+    def __call__(self, request):
+        token = request.headers.get("Authorization", "").removeprefix("Bearer ")
+        if not token or not (user := verify_token(token)):
+            return Response(status=401)
+        request.user = user
+        return self.app(request)

